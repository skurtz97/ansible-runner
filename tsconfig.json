{
    "compilerOptions": {
        "module": "node16",
        "moduleResolution": "node16",
        "target": "es2022",
        "outDir": "./out",
        "rootDir": "./src",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "types": ["node"],
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "noPropertyAccessFromIndexSignature": true,
        "noImplicitOverride": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", ".vscode-test"]
}