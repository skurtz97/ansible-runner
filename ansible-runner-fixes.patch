 Makefile                 | 117 +++++++++++++++++++++++++++++++++++++++
 src/inventoryDetector.ts |   4 +-
 src/playbookDetector.ts  |   2 +-
 src/playbookProvider.ts  |  12 ++--
 src/runner.ts            |   8 +--
 6 files changed, 131 insertions(+), 13 deletions(-)
 create mode 100644 Makefile

