{
  "name": "ansible-runner",
  "displayName": "Ansible Runner",
  "description": "Run Ansible playbooks from a sidebar tree view",
  "version": "0.1.0",
  "publisher": "skurtz",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/inventory.yml",
    "workspaceContains:**/*.yml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ansibleRunner",
          "title": "Ansible Runner",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ansibleRunner": [
        {
          "id": "ansibleRunnerPlaybooks",
          "name": "Playbooks",
          "icon": "media/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "ansibleRunner.run",
        "title": "Run Playbook",
        "icon": "$(play)"
      },
      {
        "command": "ansibleRunner.runVerbose",
        "title": "Run Playbook (Verbose)"
      },
      {
        "command": "ansibleRunner.dryRun",
        "title": "Dry Run Playbook"
      },
      {
        "command": "ansibleRunner.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ansibleRunner.refresh",
          "when": "view == ansibleRunnerPlaybooks",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ansibleRunner.run",
          "when": "view == ansibleRunnerPlaybooks && viewItem == playbook",
          "group": "1_run@1"
        },
        {
          "command": "ansibleRunner.runVerbose",
          "when": "view == ansibleRunnerPlaybooks && viewItem == playbook",
          "group": "1_run@2"
        },
        {
          "command": "ansibleRunner.dryRun",
          "when": "view == ansibleRunnerPlaybooks && viewItem == playbook",
          "group": "1_run@3"
        }
      ]
    },
    "configuration": {
      "title": "Ansible Runner",
      "properties": {
        "ansibleRunner.inventory": {
          "type": "string",
          "default": "",
          "description": "Path to inventory file. Leave empty to auto detect in workspace root."
        },
        "ansibleRunner.extraFlags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra flags to pass to ansible-playbook on every run."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.8.0"
  }
}
